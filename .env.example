# LLM via LangChain — we use Groq (free tier, no card required)
GROQ_API_KEY=gsk_...

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Logging: INFO (default), DEBUG for full graph/tool trace
LOG_LEVEL=INFO

# Frontend (for docker-compose: use http://localhost:8000 when browser talks to backend)
NEXT_PUBLIC_API_URL=http://localhost:8000
